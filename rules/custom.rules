# ============================================================
# custom.rules — Suricata IDS Home Lab
# Author: Your Name
# Description: Custom detection rules for 4 simulated attack
#              scenarios in a home lab environment.
# ============================================================

# -----------------------------------------------
# RULE 1: Nmap SYN Port Scan Detection
# Triggers when 20+ SYN packets are seen from
# the same source within 2 seconds.
# -----------------------------------------------
alert tcp any any -> $HOME_NET any (\
  msg:"NMAP SYN Scan Detected";\
  flags:S;\
  threshold: type both, track by_src, count 20, seconds 2;\
  classtype:attempted-recon;\
  sid:1000001;\
  rev:1;)

# -----------------------------------------------
# RULE 2: ICMP Ping Sweep Detection
# Triggers on 5+ ICMP echo requests from the
# same source within 2 seconds.
# -----------------------------------------------
alert icmp any any -> $HOME_NET any (\
  msg:"ICMP Ping Sweep Detected";\
  itype:8;\
  threshold: type both, track by_src, count 5, seconds 2;\
  classtype:attempted-recon;\
  sid:1000002;\
  rev:1;)

# -----------------------------------------------
# RULE 3: SSH Brute Force Detection
# Triggers when 5+ TCP connections are made to
# port 22 from the same source within 60 seconds.
# -----------------------------------------------
alert tcp any any -> $HOME_NET 22 (\
  msg:"SSH Brute Force Attempt";\
  flow:to_server;\
  threshold: type both, track by_src, count 5, seconds 60;\
  classtype:attempted-admin;\
  sid:1000003;\
  rev:1;)

# -----------------------------------------------
# RULE 4: Reverse Shell via Netcat Detection
# Triggers when /bin/sh payload is detected in
# TCP packet content (common in reverse shells).
# -----------------------------------------------
alert tcp any any -> $HOME_NET any (\
  msg:"Possible Reverse Shell - Netcat /bin/sh Payload";\
  content:"/bin/sh";\
  classtype:shellcode-detect;\
  sid:1000004;\
  rev:1;)

# -----------------------------------------------
# RULE 5 (Bonus): Nmap OS Detection Probe
# Detects Nmap OS fingerprinting attempts via
# unusual TCP flag combinations.
# -----------------------------------------------
alert tcp any any -> $HOME_NET any (\
  msg:"Possible Nmap OS Fingerprint Probe";\
  flags:SF;\
  classtype:attempted-recon;\
  sid:1000005;\
  rev:1;)

# -----------------------------------------------
# RULE 6 (Bonus): Large ICMP Packet (Ping of Death)
# Alerts on oversized ICMP echo requests > 1000 bytes.
# -----------------------------------------------
alert icmp any any -> $HOME_NET any (\
  msg:"Large ICMP Packet - Possible Ping of Death";\
  itype:8;\
  dsize:>1000;\
  classtype:denial-of-service;\
  sid:1000006;\
  rev:1;)
